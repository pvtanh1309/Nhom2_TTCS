#include "stm32f401re.h"
#include "stm32f401re_gpio.h"
#include "stm32f401re_rcc.h"

/* ===================== MACRO ===================== */
#define LED_PORT        GPIOA
#define LED_PIN         GPIO_Pin_5

#define BUTTON_PORT     GPIOC
#define BUTTON_PIN      GPIO_Pin_13

/* ===================== PROTOTYPE ===================== */
void GPIO_LED_Init(void);
void GPIO_Button_Init(void);
void LED_On(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);
void LED_Off(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);
uint8_t Button_Read(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin);
void Delay_ms(uint32_t time);

/* ===================== MAIN ===================== */
int main(void)
{
    uint8_t led_state = 0;

    GPIO_LED_Init();
    GPIO_Button_Init();

    while (1)
    {
        /* Nút PC13: nhấn = 0 */
        if (Button_Read(BUTTON_PORT, BUTTON_PIN) == 0)
        {
            Delay_ms(200);   // chống rung nút nhấn

            if (Button_Read(BUTTON_PORT, BUTTON_PIN) == 0)
            {
                led_state = !led_state;

                if (led_state)
                    LED_On(LED_PORT, LED_PIN);
                else
                    LED_Off(LED_PORT, LED_PIN);

                /* Chờ nhả nút */
                while (Button_Read(BUTTON_PORT, BUTTON_PIN) == 0);
            }
        }
    }
}

/* ===================== LED INIT ===================== */
void GPIO_LED_Init(void)
{
    GPIO_InitTypeDef GPIO_InitStructure;

    /* Cấp clock cho GPIOA */
    RCC_AHB1PeriphClockCmd(RCC_AHB1Periph_GPIOA, ENABLE);

    GPIO_InitStructure.GPIO_Pin   = LED_PIN;
    GPIO_InitStructure.GPIO_Mode  = GPIO_Mode_OUT;
    GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_InitStructure.GPIO_OType = GPIO_OType_PP;
    GPIO_InitStructure.GPIO_PuPd  = GPIO_PuPd_DOWN;

    GPIO_Init(LED_PORT, &GPIO_InitStructure);
}

/* ===================== BUTTON INIT ===================== */
void GPIO_Button_Init(void)
{
    GPIO_InitTypeDef GPIO_InitStructure;

    /* Cấp clock cho GPIOC */
    RCC_AHB1PeriphClockCmd(RCC_AHB1Periph_GPIOC, ENABLE);

    GPIO_InitStructure.GPIO_Pin   = BUTTON_PIN;
    GPIO_InitStructure.GPIO_Mode  = GPIO_Mode_IN;
    GPIO_InitStructure.GPIO_Speed = GPIO_Speed_50MHz;
    GPIO_InitStructure.GPIO_PuPd  = GPIO_PuPd_UP;

    GPIO_Init(BUTTON_PORT, &GPIO_InitStructure);
}

/* ===================== LED CONTROL ===================== */
void LED_On(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin)
{
    GPIOx->BSRRL = GPIO_Pin;   // set bit
}

void LED_Off(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin)
{
    GPIOx->BSRRH = GPIO_Pin;   // reset bit
}

/* ===================== BUTTON READ ===================== */
uint8_t Button_Read(GPIO_TypeDef* GPIOx, uint16_t GPIO_Pin)
{
    return (uint8_t)((GPIOx->IDR >> __builtin_ctz(GPIO_Pin)) & 0x01);
}

/* ===================== DELAY ===================== */
void Delay_ms(uint32_t time)
{
    uint32_t i;
    while (time--)
    {
        for (i = 0; i < 8000; i++);
    }
}
